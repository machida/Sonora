{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sonora",
  "version": "1.0.0",
  "identifier": "local.machida.sonora",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Sonora",
        "width": 660,
        "height": 640,
        "minWidth": 560,
        "minHeight": 420,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["bin/yt-dlp"],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
